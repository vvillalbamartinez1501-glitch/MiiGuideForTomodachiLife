// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  miis          Mii[]     // Miis uploaded by this user
  likes         Like[]    // Likes given by this user
  savedMiis     SavedCollection[] // Miis saved by this user
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Mii {
  id              String   @id @default(cuid())
  name            String
  series          String?
  imageUrl        String?  // The visual representation (View A)
  type            String   // e.g., "Anime", "Celebridades", "Ficticios"
  
  // JSON stringified fields for complex data
  basicImageUrl   String?  // View B (second image showing components)
  proInstructions String?  // View C (step by step)
  
  authorId        String
  author          User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  likes           Like[]
  savedBy         SavedCollection[]
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  miiId     String
  mii       Mii      @relation(fields: [miiId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, miiId])
}

model SavedCollection {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  miiId     String
  mii       Mii      @relation(fields: [miiId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, miiId])
}
